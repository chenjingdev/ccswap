{
  "name": "ccswap",
  "version": "0.1.0-alpha.1",
  "description": "Multi-account Claude Code switcher with auto-swap on limit",
  "author": "김아람 <chenjing@laonpeople.com>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ccswap": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/chenjingdev/ccswap#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenjingdev/ccswap.git"
  },
  "bugs": {
    "url": "https://github.com/chenjingdev/ccswap/issues"
  },
  "keywords": [
    "cli",
    "tui",
    "claude",
    "claude-code",
    "anthropic",
    "account-switcher",
    "auto-swap",
    "ink"
  ],
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "scripts": {
